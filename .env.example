# Copie este arquivo para .env e ajuste os valores

# Django
SECRET_KEY=troque-para-uma-chave-secreta-forte-em-producao
DEBUG=False

# Hosts permitidos — use * para qualquer host (EasyPanel/produção)
# Ou liste os domínios: meusite.easypanel.host,meudominio.com
ALLOWED_HOSTS=seu-dominio.com

# Origens confiáveis para CSRF (necessário quando usar HTTPS)
CSRF_TRUSTED_ORIGINS=https://seu-dominio.com

# Superusuário criado automaticamente na primeira execução
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@webcontrol.local
DJANGO_SUPERUSER_PASSWORD=webcontrol@2025
